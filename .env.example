# ================================
# Smart Bharat - Environment Vars
# ================================

# Get your Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (gemini-1.5-* models are fully retired — use a current model)
GEMINI_MODEL=gemini-2.5-flash

# Flask secret key (used for sessions) - generate a random string for production
SECRET_KEY=change_this_to_a_random_secret_key

# Flask environment: development | production
FLASK_ENV=production

# Port (used by some hosts like Render/Railway)
PORT=5000

# Path to SQLite database file
DATABASE_PATH=database/smart_bharat.db
